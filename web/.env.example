# Copy this file to `.env` in this directory and fill in values.
# Never commit `.env` — it is listed in `.gitignore`.
#
# If you also use `.env.local`, it OVERRIDES `.env` for any duplicate variable.

# MongoDB Atlas (recommended) — see setup steps in README or below.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/jobhunt?retryWrites=true&w=majority"

# Optional: allow Next.js dev HMR when you open the site from another host on your LAN
# ALLOWED_DEV_ORIGINS=192.168.110.127

# Auth.js v5 (NextAuth) — https://authjs.dev/getting-started/installation
# Generate a strong secret: `npx auth secret`  (or `openssl rand -base64 32`)
AUTH_SECRET=""
# Public URL of this app (required for OAuth callbacks in many setups).
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (Gmail / Google account) — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: GitHub OAuth — https://github.com/settings/developers
# Callback URL: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Optional: employer ATS boards (comma-separated). If unset, JOB HUNT uses built-in lists.
# ATS_GREENHOUSE_BOARDS=stripe,notion,yourcompany
# ATS_LEVER_SITES=leverdemo,yourcompany

# Optional AI tailoring
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
