# Copy to `.env` and fill in real values. Never commit `.env`.

# MongoDB Atlas connection string
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/jobhunt?retryWrites=true&w=majority"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="your-long-random-secret-here"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# AI tailoring (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ATS board overrides (optional, comma-separated)
# ATS_GREENHOUSE_BOARDS=stripe,notion
# ATS_LEVER_SITES=leverdemo
